# Resend (https://resend.com) — transactional email
# Without this, contact form and waitlist welcome emails are skipped (no-op)
RESEND_API_KEY=re_xxxx

# Optional: override default "from" domain (Resend verifies your domain)
# EMAIL_FROM=VibeTree <hello@vibetree.com>

# Site URL for links in emails (waitlist referral, etc.)
# NEXT_PUBLIC_SITE_URL=https://vibetree.com

# Firebase Auth (client) — enable real auth. Without these, auth uses mock localStorage.
# Get from Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Optional (defaults derived from projectId):
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
