# Resend (https://resend.com) — transactional email
# Without this, contact form and waitlist welcome emails are skipped (no-op)
RESEND_API_KEY=re_xxxx

# Optional: override default "from" domain (Resend verifies your domain)
# EMAIL_FROM=VibeTree <hello@vibetree.com>

# Site URL for links in emails (waitlist referral, etc.)
# NEXT_PUBLIC_SITE_URL=https://vibetree.com
