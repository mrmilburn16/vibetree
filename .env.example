# Vibetree environment variables
# Copy to .env.local and fill in values

# ── Core ──
ANTHROPIC_API_KEY=sk-ant-...
MAC_RUNNER_TOKEN=your-mac-runner-secret

# Public URL for the app (used for OAuth callbacks, integration links)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Pre-wired integrations ──

# X (Twitter)
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_ID_SECRET=your-twitter-client-secret

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=Vibetree <noreply@yourdomain.com>

# Stripe
STRIPE_SECRET_KEY=sk_...

# Google (Sign-In)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Firebase (optional, for Firestore sync) ──
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
