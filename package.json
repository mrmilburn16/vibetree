    "dev:mock": "NEXT_PUBLIC_USE_REAL_LLM=false next dev -p 3002",
    "dev:full:mock": "NEXT_PUBLIC_USE_REAL_LLM=false node scripts/run-dev-with-runner.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:full": "node scripts/run-dev-with-runner.mjs",
    "mac-runner": "node scripts/mac-runner.mjs",
    "mac-runner:mock": "VIBETREE_SERVER_URL=http://localhost:3002 node scripts/mac-runner.mjs",
    "test:build-results": "node scripts/test-build-results-log.mjs",
    "ios:install": "bash scripts/ios-companion-install.sh",
    "vercel:status": "node scripts/vercel-build-status.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
